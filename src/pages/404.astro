---
import Base from "../layouts/Base.astro";
---

<Base title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="max-w-3xl mx-auto px-4 py-24 text-center">
    <h1 class="text-6xl font-bold text-accent mb-4">404</h1>
    <p class="text-xl text-themed-muted mb-8">The page you're looking for doesn't exist.</p>
    <a href="/" class="text-accent hover:underline font-medium">&larr; Back to blog</a>
  </div>
</Base>
