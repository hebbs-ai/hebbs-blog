---
import Base from "./Base.astro";
import FormattedDate from "../components/FormattedDate.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, tags = [] } = Astro.props;

const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const shareText = `${title}`;
const xUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
const hnUrl = `https://news.ycombinator.com/submitlink?u=${encodeURIComponent(pageUrl)}&t=${encodeURIComponent(title)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  ...(heroImage && { image: new URL(heroImage, Astro.site).href }),
  author: {
    "@type": "Organization",
    name: "HEBBS",
    url: "https://hebbs.ai",
  },
  publisher: {
    "@type": "Organization",
    name: "HEBBS",
    url: "https://hebbs.ai",
    logo: {
      "@type": "ImageObject",
      url: new URL("/logo-icon.svg", Astro.site).href,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).href,
  },
};
---

<Base title={title} description={description} type="article" pubDate={pubDate} updatedDate={updatedDate} image={heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <div class="text-sm text-themed-muted mb-3">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <span>
            &middot; Updated <FormattedDate date={updatedDate} />
          </span>
        )}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-themed leading-tight mb-4">{title}</h1>
      <p class="text-lg text-themed-muted">{description}</p>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}/`}
              class="text-xs px-2 py-1 rounded-md bg-accent/10 text-accent font-medium hover:bg-accent/20 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="w-full rounded-lg mb-8 object-cover aspect-video"
      />
    )}
    <div class="prose text-themed">
      <slot />
    </div>
    <footer class="mt-12 pt-6 border-t border-themed">
      <div class="flex items-center gap-4">
        <span class="text-sm text-themed-muted">Share</span>
        <a href={xUrl} target="_blank" rel="noopener noreferrer" class="text-themed-muted hover:text-accent transition-colors" title="Share on X">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="text-themed-muted hover:text-accent transition-colors" title="Share on LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={hnUrl} target="_blank" rel="noopener noreferrer" class="text-themed-muted hover:text-accent transition-colors" title="Share on Hacker News">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm12.8 13.4V19h-1.6v-5.6L7 5h1.8l3.2 5.8L15.2 5H17l-4.2 8.4z"/></svg>
        </a>
      </div>
    </footer>
  </article>
</Base>
