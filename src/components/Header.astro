---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="border-b border-themed">
  <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="https://hebbs.ai" class="flex items-center gap-2 text-themed hover:text-accent transition-colors">
      <img src="/favicon.svg" alt="HEBBS" width="24" height="24" />
