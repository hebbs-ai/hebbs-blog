    </a>
    <div class="flex items-center gap-4">
      <a href="/" class="text-sm text-themed-muted hover:text-accent transition-colors">Posts</a>
      <a href="/rss.xml" class="text-sm text-themed-muted hover:text-accent transition-colors">RSS</a>
      <a href="https://hebbs.ai" class="text-sm text-themed-muted hover:text-accent transition-colors" target="_blank" rel="noopener">hebbs.ai</a>
      <ThemeToggle />
    </div>
