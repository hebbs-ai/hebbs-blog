---
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle theme"
  class="p-2 rounded-lg border border-themed text-themed-muted hover:text-accent transition-colors cursor-pointer"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg id="icon-sun" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg id="icon-moon" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
  <!-- Auto icon (system) -->
  <svg id="icon-auto" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
  </svg>
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    const iconSun = document.getElementById("icon-sun");
    const iconMoon = document.getElementById("icon-moon");
    const iconAuto = document.getElementById("icon-auto");

    if (!btn || !iconSun || !iconMoon || !iconAuto) return;

    type Theme = "light" | "dark" | "auto";
    const cycle: Theme[] = ["light", "dark", "auto"];

    function getTheme(): Theme {
      const stored = localStorage.getItem("theme");
      if (stored === "light" || stored === "dark") return stored;
      return "auto";
    }

    function applyTheme(theme: Theme) {
      const isDark =
        theme === "dark" ||
        (theme === "auto" && window.matchMedia("(prefers-color-scheme: dark)").matches);

      document.documentElement.classList.toggle("dark", isDark);

      iconSun.classList.toggle("hidden", theme !== "dark");
      iconMoon.classList.toggle("hidden", theme !== "light");
      iconAuto.classList.toggle("hidden", theme !== "auto");

      btn.setAttribute("aria-label", `Theme: ${theme}. Click to change.`);
    }

    function setTheme(theme: Theme) {
      if (theme === "auto") {
        localStorage.removeItem("theme");
      } else {
        localStorage.setItem("theme", theme);
      }
      applyTheme(theme);
    }

    applyTheme(getTheme());

    btn.addEventListener("click", () => {
      const current = getTheme();
      const next = cycle[(cycle.indexOf(current) + 1) % cycle.length];
      setTheme(next);
    });

    window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
      if (getTheme() === "auto") applyTheme("auto");
    });
  }

  initThemeToggle();
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>
